from abc import ABC, abstractmethod
from datetime import datetime

# АБСТРАКТНИЙ БАЗОВИЙ КЛАС

class FileSystemObject(ABC):

    def __init__(self, name, path, size):
        self.__name = name                  # приватний атрибут
        self.__path = path                  # приватний атрибут
        self.__created_date = datetime.now()
        self.__size = size

  
    # PROPERTY ДЛЯ ІНКАПСУЛЯЦІЇ

    @property
    def name(self):
        return self.__name

    @name.setter
    def name(self, value):
        self.__name = value

    @property
    def path(self):
        return self.__path

    @path.setter
    def path(self, value):
        self.__path = value

    @property
    def created_date(self):
        return self.__created_date

    @property
    def size(self):
        return self.__size

    @size.setter
    def size(self, value):
        self.__size = value


    # АБСТРАКТНИЙ МЕТОД


    @abstractmethod
    def get_info(self):
        pass



# КЛАС File


class File(FileSystemObject):

    def __init__(self, name, path, size, extension):
        super().__init__(name, path, size)

        self.__extension = extension

    @property
    def extension(self):
        return self.__extension

    @extension.setter
    def extension(self, value):
        self.__extension = value

    # Поліморфізм
    def get_info(self):
        return (
            f"Файл: {self.name}\n"
            f"Шлях: {self.path}\n"
            f"Розмір: {self.size} КБ\n"
            f"Розширення: {self.extension}\n"
        )



# КЛАС TextFile


class TextFile(File):

    def __init__(self, name, path, size, extension, content):
        super().__init__(name, path, size, extension)

        self.__content = content

    @property
    def content(self):
        return self.__content

    @content.setter
    def content(self, value):
        self.__content = value

    # Поліморфізм
    def get_info(self):
        return (
            f"Текстовий файл: {self.name}\n"
            f"Шлях: {self.path}\n"
            f"Розмір: {self.size} КБ\n"
            f"Вміст: {self.content}\n"
        )



# КЛАС ImageFile


class ImageFile(File):

    def __init__(self, name, path, size,
                 extension, width, height):

        super().__init__(name, path, size, extension)

        self.__width = width
        self.__height = height

    @property
    def width(self):
        return self.__width

    @property
    def height(self):
        return self.__height

    # Поліморфізм
    def get_info(self):
        return (
            f"Графічний файл: {self.name}\n"
            f"Шлях: {self.path}\n"
            f"Розмір: {self.size} КБ\n"
            f"Роздільна здатність: "
            f"{self.width}x{self.height}\n"
        )



# КЛАС Folder


class Folder(FileSystemObject):

    def __init__(self, name, path):
        super().__init__(name, path, 0)

        self.__objects = []  # список об'єктів

    # Додавання об'єктів
    def add_object(self, obj):
        self.__objects.append(obj)

    @property
    def objects(self):
        return self.__objects

    # Поліморфізм
    def get_info(self):
        info = (
            f"Папка: {self.name}\n"
            f"Шлях: {self.path}\n"
            f"Кількість об'єктів: "
            f"{len(self.__objects)}\n"
        )

        return info



# ГОЛОВНА ПРОГРАМА


# Створення текстового файлу
text_file = TextFile(
    "notes.txt",
    "C:/Documents",
    15,
    ".txt",
    "Привіт, це текстовий файл"
)

# Створення графічного файлу
image_file = ImageFile(
    "photo.png",
    "C:/Images",
    2500,
    ".png",
    1920,
    1080
)

# Створення папки
folder = Folder(
    "MyFolder",
    "C:/"
)

# Додавання файлів у папку
folder.add_object(text_file)
folder.add_object(image_file)



# ВИВІД ІНФОРМАЦІЇ


print("===== ІНФОРМАЦІЯ ПРО ФАЙЛИ =====\n")

print(text_file.get_info())

print(image_file.get_info())

print(folder.get_info())


print("===== ОБ'ЄКТИ В ПАПЦІ =====\n")

for obj in folder.objects:
    print(obj.get_info())

